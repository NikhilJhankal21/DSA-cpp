class Solution {
public:
    int numberOfSpecialChars(string word) {
        int count=0;
        int n=word.length();
        vector<int>lastOccsmall(26,-1);
        vector<int>firstOccCapital(26,-1);
        for(int i=0;i<n;i++){
            char ch=word[i];
            if(islower(ch)){
                lastOccsmall[ch-'a']=i;
            }else{
                if(firstOccCapital[ch-'A']==-1){
                firstOccCapital[ch-'A']=i;
                }
            }
        }
        for(int i=0;i<26;i++){
            if(lastOccsmall[i]!=-1 && firstOccCapital[i]!=-1 && lastOccsmall[i]<firstOccCapital[i]){
                count++;
            }
        }
        return count;
    }
};
