class Solution {
public:
    int differenceOfSum(vector<int>& nums) {
        int n=nums.size();
        int sum=accumulate(nums.begin(),nums.end(),0);
        int digitsum=0;
        for(auto x:nums){
            if(x>=0 && x<=9){
                digitsum+=x;
            }else{
                while(x>0){
                    digitsum+=x%10;
                    x/=10;
                }
            }
        }    
        return abs(sum-digitsum);
    }
};
