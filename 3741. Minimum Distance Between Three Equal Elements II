class Solution {
public:
    int minimumDistance(vector<int>& nums) {
        unordered_map<int, vector<int>> idx;
        int n = nums.size();
        int ans = INT_MAX;
        // Sare indexes store karo har number ke liye
        for(int i = 0; i < n; i++) {
            idx[nums[i]].push_back(i);
        }
        // Har number ke liye, agar 3 ya usse zyada baar aaya toh check karo
        for(auto &p : idx) {
            vector<int>& v = p.second;
            if(v.size() >= 3) {
                for(int i = 2; i < v.size(); i++) {
                    int first=v[i-2];
                    int mid=v[i-1];
                    int last=v[i];
                    int dist = abs(first- mid) +abs(mid-last) +abs(last-first);
                    ans = min(ans, dist);
                }
            }
        }
        return ans == INT_MAX ? -1 : ans;
    }
};
