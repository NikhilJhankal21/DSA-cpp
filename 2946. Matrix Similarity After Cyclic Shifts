class Solution {
public:
    bool areSimilar(vector<vector<int>>& mat, int k) {
    int m = mat.size();
    vector<vector<int>> original = mat; 
    for(int i = 0; i < m; i++) {
        int n = mat[i].size();
        int shift = k % n;

        if(i % 2 == 0) {
            // even row → left rotate
            rotate(begin(mat[i]), begin(mat[i]) + shift, end(mat[i]));
        } else {
            // odd row → right rotate
            rotate(rbegin(mat[i]), rbegin(mat[i]) + shift, rend(mat[i]));
        }
    }

    return mat == original;
   }
};
