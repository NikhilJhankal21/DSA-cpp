class Solution {
public:
    string compressedString(string word) {
        int n=word.size();
        string comp="";
        int i=0;
        while(i<n){
            int length=1;
            while(i+1 < n && word[i]==word[i+1] && length<9){
                length++;
                i++;
            }
            comp.push_back(length+'0');
            comp.push_back(word[i]);
            i++;
        }
        return comp;
    }
};
