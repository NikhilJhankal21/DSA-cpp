class Solution {
public:
    int totalWaviness(int start, int end) {
        int ans = 0;
        for (int num = start; num <= end; num++) {
            string s = to_string(num);
            for (int i = 1; i < s.size() - 1; i++) {
                // Peak
                if (s[i] > s[i - 1] && s[i] > s[i + 1]) {
                    ans++;
                }
                // Valley
                else if (s[i] < s[i - 1] && s[i] < s[i + 1]) {
                    ans++;
                }
            }
        }

        return ans;
    }
};
