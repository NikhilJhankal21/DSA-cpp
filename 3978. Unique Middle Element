class Solution {
public:
    bool isMiddleElementUnique(vector<int>& nums) {
        int n=nums.size();
        if(n==1) return true;
        int middle=n/2;
        unordered_map<int,int>mp;
        for(auto x:nums){
            mp[x]++;
        }
        if(mp[nums[middle]]>1){
            return false;
        }
        return true;
    }
};
