class Solution {
public:
    Node* flatten(Node* head) {
        if(head==NULL) return head;

        Node*curr=head;
        while(curr!=NULL){
            if(curr->child!=NULL){
                // Flatten child Nodes
                Node*next=curr->next;
                curr->next=flatten(curr->child);

                curr->next->prev=curr;
                curr->child=NULL;

                // Find tail
                while(curr->next!=NULL){
                    curr=curr->next;
                    
                }
                // Attach tail with next ptr
                if(next!=NULL){
                   curr->next=next;
                   next->prev=curr; 
                }
            }
            curr=curr->next;
        }
        return head;
    }
};
