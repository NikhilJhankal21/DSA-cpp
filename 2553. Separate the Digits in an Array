class Solution {
public:
    vector<int> separateDigits(vector<int>& nums) {
        vector<int>ans;
        for(auto x:nums){
            string s = to_string(x);
            for(auto a:s){
                ans.push_back(a-'0');  // To convert a char into number 
            }
        }
        return ans;
    }
};
