// Find endzeroes or trailing zeroes = no of continous 0s in the end

// For each row (i) -> check need 0s n-i-1  and check the nearest row having 0s>=need

// If not found return -1  else steps to swap = j-i 


class Solution {
public:
    int minSwaps(vector<vector<int>>& grid) {
        int n=grid.size();
        vector<int>endZeroes(n,0);
        // endZeroes[i]=count of consecutive 0s from the end to the ith row
        for(int i=0;i<n;i++){
            int j=n-1; // Start from end
            int count=0;
            while(j>=0 &&  grid[i][j]==0){
                count++;
                j--;
            }
            endZeroes[i]=count;
        }
        int steps=0;
        for(int i=0;i<n;i++){
            int need=n-i-1;

            int j=i;
            while(j<n && endZeroes[j]<need){
                j++;
            }
            if(j==n){
                return -1;
            }
            steps+=j-i;
            while(j>i){
                swap(endZeroes[j],endZeroes[j-1]);
                j--;
            }

        }
        return steps;
    }
};
