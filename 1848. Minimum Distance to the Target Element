class Solution {
public:
    int getMinDistance(vector<int>& nums, int target, int start) {
        int n=nums.size();
        int idx=-1;
        int ans =INT_MAX;
        for(int i=0;i<n;i++){
            if(nums[i]==target){
                idx=i;
                ans=min(ans,abs(i-start));
            }
        }
        return ans;
    }
};
