class Solution {
public:
    void getAllCombinations(vector<int>& arr, int idx, int target, vector<vector<int>>& ans, vector<int>& combination) {
        if(target<0){
            return;
        }
        if (target == 0) {
            ans.push_back(combination);
            return;
        }
        for (int i = idx; i < arr.size(); i++) {
            // skip duplicates
            if (i > idx && arr[i] == arr[i - 1]) continue;
            combination.push_back(arr[i]);
            // move to next index
            getAllCombinations(arr, i + 1, target - arr[i], ans, combination);
            combination.pop_back(); // backtracking
        }
    }

    vector<vector<int>> combinationSum2(vector<int>& arr, int target) {
        vector<vector<int>> ans;
        vector<int> combination;
        sort(arr.begin(), arr.end()); // important
        getAllCombinations(arr, 0, target, ans, combination);
        return ans;
    }
};
