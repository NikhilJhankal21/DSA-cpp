class Solution {
public:
    int findMaxConsecutiveOnes(vector<int>& nums) {
        int n=nums.size();
        int maxSum=INT_MIN;
        for(int i=0;i<n;i++){
            int currentSum;
            if(nums[i]==0){  // Kadane's Algorithm 
                currentSum=0; 
            }
            else{
                currentSum+=nums[i];
            }
            maxSum=max(maxSum,currentSum);
        }
        return maxSum; 
    }
};
