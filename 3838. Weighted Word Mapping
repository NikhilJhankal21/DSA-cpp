class Solution {
public:
    string mapWordWeights(vector<string>& words, vector<int>& weights) {
        string ans="";
        for(auto s:words){
            int total=0;
            for(auto ch :s){
                total+=weights[ch-'a'];
            }
            int mod=total%26;
            ans+=char('z'-mod);
        }
        return ans;
    }
};
