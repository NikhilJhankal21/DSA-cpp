class Solution {
public:
    string makeGood(string s) {
        int n=s.length();
        string ans="";
        ans.push_back(s[0]);
        for(int i=1;i<n;i++){
            if(!ans.empty() && (ans.back()+32==s[i] || ans.back()-32==s[i])){
                ans.pop_back();
            }else{
                ans.push_back(s[i]);
            }
        }
        return ans;
    }
};
