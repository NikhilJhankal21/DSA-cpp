class Solution {
public:
    int minimumSwaps(vector<int>& nums) {
        int zeroes=0;
        int n=nums.size();
        for(int i=0;i<n;i++){
            if(nums[i]==0){
                zeroes++;
            }
        }
        int ans=0;
        for(int i=n-zeroes; i<n;i++){
            if(nums[i]!=0){
                ans++;
            }
        }
        return ans;
        
    }
};
