class Solution {
public:
    bool asteroidsDestroyed(int mass, vector<int>& asteroids) {
        sort(asteroids.begin(),asteroids.end());
        long long totalMass=mass;
        int n=asteroids.size();
        for(int i=0;i<n;i++){
            if(totalMass>=asteroids[i]){
                totalMass+=asteroids[i];
            }else{
                return false;
            }
        }
        return true;
    }
};
