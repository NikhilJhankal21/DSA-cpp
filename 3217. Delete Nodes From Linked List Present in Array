class Solution {
public:
    ListNode* modifiedList(vector<int>& nums, ListNode* head) {
        unordered_set<int> st(nums.begin(), nums.end());
        ListNode* dummy = new ListNode(0);
        ListNode* tail = dummy;
        ListNode* temp = head;

        while(temp != NULL) {
            if(st.count(temp->val)) {
                temp=temp->next;
                continue;
            } else {
                tail->next = temp;
                tail = temp;
            }

            temp = temp->next;
        }
        tail->next=NULL;
        return dummy->next;
    }
};
