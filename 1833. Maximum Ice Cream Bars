class Solution {
public:
    int maxIceCream(vector<int>& costs, int coins) {
        int n=costs.size();
        int max=0;
        sort(costs.begin(),costs.end());
        for(int i=0;i<n;i++){
            if(coins>=costs[i]){
                max++;
                coins-=costs[i];
            }
        }
        return max;
    }
};
