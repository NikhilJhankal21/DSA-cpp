class Solution {      
public:   
    int apnaLowerBound(int l,int r,vector<int>&potions,int minPotions){
        int possibleIndex=-1;
        int mid=0;
        while(l<=r){
            mid =l+(r-l)/2;
            if(potions[mid]>=minPotions){
                possibleIndex=mid;
                r=mid-1;
            }else{
                l=mid+1;
            }
        }
        return possibleIndex;
    }
    vector<int> successfulPairs(vector<int>& spells, vector<int>& potions, long long success) {
        int n=spells.size();
        int m=potions.size();
        sort(potions.begin(),potions.end());
        int maxpotionValue=potions[m-1];
        vector<int>answer;
        for(int i=0;i<n;i++){
            int spell=spells[i];
            long long minPotion=ceil((1.0*success)/spell);
            
            if(minPotion>maxpotionValue){
                answer.push_back(0);
                continue;
            }
            int index =apnaLowerBound(0,m-1,potions,minPotion);
            int count=m-index;
            answer.push_back(count);
        }
        return answer;
    }
};
