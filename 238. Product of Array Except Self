class Solution {
public:
    vector<int> productExceptSelf(vector<int>& nums) {
        int n =nums.size();
        vector<int> ans(n);
        // Prefix product Array in ans directly
        ans[0]=1;
        for(int i=1;i<n;i++){
            ans[i]=ans[i-1]*nums[i-1];
        }
        // Suffix product array (In prefix only)
        int suffix=1;
        for(int i=n-2;i>=0;i--){
            suffix*=nums[i+1];       
            ans[i]*=suffix;
        }
        return ans;
    }
};   
